# Canaux d'alerte du radar (npm run monitor). Copie ce fichier en .env et adapte.
# Tous optionnels : la console affiche toujours les alertes.

# --- ntfy.sh : push téléphone, zéro compte (RECOMMANDÉ) ---
# Choisis un topic secret/unique, puis abonne-toi dans l'app ntfy (iOS/Android)
# ou ouvre https://ntfy.sh/<TON_TOPIC> dans un navigateur.
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh   # serveur ntfy custom si self-hosted

# --- macOS : notification + son (auto-activé sur Mac) ---
# ALERT_MACOS=1

# --- Telegram (optionnel) : crée un bot via @BotFather, récupère ton chat id ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Webhook générique (optionnel) : Slack / Discord / Zapier (POST JSON) ---
# WEBHOOK_URL=
